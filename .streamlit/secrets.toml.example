# Owner's keys — set in Streamlit Cloud dashboard for prod deploy.
# For local dev: copy this to .streamlit/secrets.toml (gitignored) and fill in values.
#
# NEVER commit .streamlit/secrets.toml — it contains real credentials.

APP_PASSWORD = "change-me"    # required: visitors enter this before seeing the app

TIINGO_API_KEY = "..."        # required for news ingestion (Phase 0 onward)
FRED_API_KEY = "..."          # required for macro data

# NOTE: OPENAI_API_KEY is NOT set here — visitors paste their own key in the sidebar.
# GITHUB_TOKEN is added in Phase 1 for the freshness banner timestamp.
